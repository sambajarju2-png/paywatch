{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@paywatch/ui": ["../../packages/ui/src/index.ts"],
      "@paywatch/ui/*": ["../../packages/ui/src/*"],
      "@paywatch/database": ["../../packages/database/src/index.ts"],
      "@paywatch/database/*": ["../../packages/database/src/*"],
      "@paywatch/config": ["../../packages/config/src/index.ts"],
      "@paywatch/config/*": ["../../packages/config/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
