{
  "name": "paywatch",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:landing": "turbo dev --filter=@paywatch/landing",
    "dev:web": "turbo dev --filter=@paywatch/web",
    "dev:admin": "turbo dev --filter=@paywatch/admin",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@remixicon/react": "^4.9.0",
    "@tremor/react": "^3.18.7"
  }
}
